{
  "name": "@ckb-vote/sdk",
  "version": "0.1.0",
  "description": "Off-chain SDK for CKB vote proposal lifecycle: create, vote, consume",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ckb-vote": "./bin/ckb-vote.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bun": "tsc --emitDeclarationOnly && bun build src/index.ts --outfile=dist/index.js --target=node --format=esm",
    "dev": "tsx src/cli/index.ts",
    "dev:bun": "bun run src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:create-proposal": "tsx src/cli/index.ts create-proposal --private-key-file ../tools/e2e/pk1 --duration 3 --description \"test1\""
  },
  "dependencies": {
    "@ckb-ccc/shell": "^1.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "onlyBuiltDependencies": [
    "esbuild"
  ],
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}
